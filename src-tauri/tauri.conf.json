{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "win-wallpaper",
  "version": "0.3.0",
  "identifier": "com.lsoapps.winwallpaper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Switch Bar",
        "label": "switch-bar",
        "url": "switch-bar.html",
        "width": 1200,
        "height": 200,
        "skipTaskbar": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "shadow": false,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "allowDowngrades": true,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      },
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false,
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      },
      "wix": null
    },
    "icon": [
      "icons/logoww.png",
      "icons/logoww.ico"
    ]
  }
}
