{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["wallpaper-*", "switch-bar"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:default",
    "wallpaper:default",
    "allow-get-wallpapers",
    "allow-set-wallpaper-config",
    "allow-get-default-wallpaper",
    "allow-get-widgets",
    "allow-get-monitors",
    "allow-get-monitor-wallpaper",
    "allow-set-monitor-wallpaper",
    "allow-get-monitor-widgets",
    "allow-set-monitor-widgets",
    "allow-get-active-setup",
    "allow-set-active-setup",
    "allow-refresh-app",
    "global-shortcut:default"
  ]
}
